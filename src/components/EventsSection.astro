---
const events = [
  {
    id: 1,
    title: "Hamamatsu Micro Maker Faire 2026",
    date: "2026.07.04",
    location: "浜松科学館",
    status: "upcoming",
    badgeLabel: "予定",
    description: "浜松で開催されるMicro Maker Faireに出展予定",
    link: "#",
  },
  {
    id: 2,
    title: "NT金沢 2026",
    date: "2026.06.28",
    location: "金沢駅東もてなしドーム地下広場",
    status: "upcoming",
    badgeLabel: "確定",
    description: "NT金沢2026への出展が確定",
    link: "#",
  },
  {
    id: 3,
    title: "NT京都 2026",
    date: "2026.03.21",
    location: "京都西院 春日神社",
    status: "past",
    description: "Pokorinta 2を初めて公開・展示",
    link: "#",
  },
  {
    id: 4,
    title: "NT金沢 2025",
    date: "2025.06.22",
    location: "金沢駅東もてなしドーム地下広場",
    status: "past",
    description: "Pokorintaの二回目の展示",
    link: "#",
  },
  {
    id: 5,
    title: "NT京都 2025",
    date: "2025.03.22-23",
    location: "京都西院 春日神社",
    status: "past",
    description: "Pokorintaを初めて公開・展示",
    link: "#",
  },
]

const upcomingEvents = events.filter((event) => event.status === "upcoming")
const pastEvents = events.filter((event) => event.status === "past")
---

<section id="events" class="relative py-16 md:py-20">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-background via-neon-orange/[0.02] to-background"></div>

  <div class="relative mx-auto max-w-4xl px-4 md:px-6">
    <!-- Section header -->
    <div class="mb-10 text-center md:mb-12">
      <div class="mb-4 flex items-center justify-center gap-3">
        <div class="h-px w-8 bg-neon-orange"></div>
        <span class="font-mono text-xs tracking-[0.2em] text-neon-orange">EVENTS</span>
        <div class="h-px w-8 bg-neon-orange"></div>
      </div>
      <h2 class="font-mono text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        展示会情報
      </h2>
      <p class="mt-3 text-sm text-muted-foreground md:text-base">出展予定を中心に、過去展示は一覧でコンパクトに掲載しています。</p>
    </div>

    <div class="space-y-6 md:space-y-8">
      <div class="space-y-4">
        <div class="flex items-center justify-between gap-3">
          <h3 class="font-mono text-sm tracking-[0.18em] text-neon-orange">UPCOMING</h3>
          <span class="h-px flex-1 bg-gradient-to-r from-neon-orange/40 to-transparent"></span>
        </div>

        <div class="grid gap-4">
          {upcomingEvents.map((event) => (
            <article class="relative overflow-hidden rounded-lg border border-neon-orange/30 bg-neon-orange/5 px-5 py-4 transition-all duration-300 hover:border-neon-orange/50">
              <div class="absolute right-4 top-4">
                <span class="flex items-center gap-1 rounded-full border border-neon-orange/50 bg-neon-orange/10 px-3 py-1 font-mono text-[11px] text-neon-orange">
                  <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-neon-orange"></span>
                  {event.badgeLabel ?? "予定"}
                </span>
              </div>

              <div class="pr-20">
                <div class="mb-2 flex flex-wrap items-center gap-x-4 gap-y-2 text-muted-foreground">
                  <div class="flex items-center gap-2">
                    <svg class="h-4 w-4 text-neon-orange" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <span class="font-mono text-sm">{event.date}</span>
                  </div>
                  <div class="flex items-center gap-2 text-sm">
                    <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <span>{event.location}</span>
                  </div>
                </div>

                <h4 class="mb-1 font-mono text-lg font-bold text-foreground">{event.title}</h4>
                <p class="text-sm leading-relaxed text-muted-foreground">{event.description}</p>

                {event.link !== "#" && (
                  <a
                    href={event.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-3 inline-flex items-center gap-2 font-mono text-xs text-neon-orange transition-colors hover:text-neon-orange/80"
                  >
                    詳細を見る
                    <svg class="h-3 w-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="space-y-4">
        <div class="flex items-center justify-between gap-3">
          <h3 class="font-mono text-sm tracking-[0.18em] text-neon-blue">ARCHIVE</h3>
          <span class="h-px flex-1 bg-gradient-to-r from-neon-blue/40 to-transparent"></span>
        </div>

        <div class="rounded-xl border border-border/50 bg-card/20 px-4 py-4 md:px-5">
          <div class="divide-y divide-border/50">
          {pastEvents.map((event) => (
            <article class="grid gap-2 py-3 first:pt-0 last:pb-0 md:grid-cols-[140px_minmax(0,1fr)] md:gap-4">
              <div class="font-mono text-xs text-neon-blue md:text-sm">{event.date}</div>
              <div class="min-w-0">
                <div class="flex flex-col gap-1 md:flex-row md:items-baseline md:justify-between md:gap-4">
                  <h4 class="font-mono text-sm font-bold text-foreground md:text-base">{event.title}</h4>
                  <div class="flex items-center gap-1.5 text-xs text-muted-foreground md:text-sm">
                    <svg class="h-3.5 w-3.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <span>{event.location}</span>
                  </div>
                </div>
                <p class="mt-1 text-sm text-muted-foreground">{event.description}</p>
              </div>
            </article>
          ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

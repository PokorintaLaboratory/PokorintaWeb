---
const events = [
  {
    id: 1,
    title: "Hamamatsu Micro Maker Faire 2026",
    date: "2026.07.04",
    location: "浜松科学館",
    status: "upcoming",
    description: "浜松で開催されるMicro Maker Faireに出展予定",
    link: "#",
  },
  {
    id: 2,
    title: "NT金沢 2026",
    date: "2026.06.28",
    location: "金沢駅東もてなしドーム地下広場",
    status: "upcoming",
    description: "NT金沢2026に出展予定",
    link: "#",
  },
  {
    id: 3,
    title: "NT京都 2026",
    date: "2026.03.21",
    location: "京都西院 春日神社",
    status: "past",
    description: "Pokorinta 2を初めて公開・展示",
    link: "#",
  },
  {
    id: 4,
    title: "NT金沢 2025",
    date: "2025.06.22",
    location: "金沢駅東もてなしドーム地下広場",
    status: "past",
    description: "Pokorintaの二回目の展示",
    link: "#",
  },
  {
    id: 5,
    title: "NT京都 2025",
    date: "2025.03.22-23",
    location: "京都西院 春日神社",
    status: "past",
    description: "Pokorintaを初めて公開・展示",
    link: "#",
  },
]
---

<section id="events" class="relative py-24">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-background via-neon-orange/[0.02] to-background"></div>

  <div class="relative mx-auto max-w-4xl px-4 md:px-6">
    <!-- Section header -->
    <div class="mb-16 text-center">
      <div class="mb-4 flex items-center justify-center gap-3">
        <div class="h-px w-8 bg-neon-orange"></div>
        <span class="font-mono text-xs tracking-[0.2em] text-neon-orange">EVENTS</span>
        <div class="h-px w-8 bg-neon-orange"></div>
      </div>
      <h2 class="font-mono text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        展示会情報
      </h2>
      <p class="mt-4 text-muted-foreground">出展予定・過去の活動履歴</p>
    </div>

    <!-- Timeline -->
    <div class="relative ml-6 space-y-6 border-l border-border/50 pl-6">
      {events.map((event) => {
        const isUpcoming = event.status === "upcoming"
        return (
          <div class="group relative">
            <!-- Timeline dot -->
            <div class="absolute -left-[29px] top-0 flex h-full flex-col items-center">
              <div class={`h-4 w-4 rounded-full border-2 ${isUpcoming ? "border-neon-orange bg-neon-orange/20" : "border-neon-blue bg-neon-blue/20"}`}></div>
              <div class="h-full w-px bg-border/50"></div>
            </div>

            <!-- Card -->
            <div class={`relative overflow-hidden rounded-lg border p-6 transition-all duration-300 ${isUpcoming ? "border-neon-orange/30 bg-neon-orange/5 hover:border-neon-orange/50" : "border-border/50 bg-card/30 hover:border-neon-blue/30 hover:bg-card/50"}`}>
              <!-- Status badge -->
              {isUpcoming && (
                <div class="absolute right-4 top-4">
                  <span class="flex items-center gap-1 rounded-full border border-neon-orange/50 bg-neon-orange/10 px-3 py-1 font-mono text-xs text-neon-orange">
                    <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-neon-orange"></span>
                    予定
                  </span>
                </div>
              )}

              <div class="mb-3 flex items-center gap-4">
                <div class="flex items-center gap-2 text-muted-foreground">
                  <!-- Calendar icon -->
                  <svg class={`h-4 w-4 ${isUpcoming ? "text-neon-orange" : "text-neon-blue"}`} xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  <span class="font-mono text-sm">{event.date}</span>
                </div>
              </div>

              <h3 class="mb-2 font-mono text-lg font-bold text-foreground">{event.title}</h3>

              <div class="mb-3 flex items-center gap-2 text-muted-foreground">
                <!-- MapPin icon -->
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span class="text-sm">{event.location}</span>
              </div>

              <p class="mb-4 text-sm leading-relaxed text-muted-foreground">{event.description}</p>

              {event.link !== "#" && (
                <a
                  href={event.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`inline-flex items-center gap-2 font-mono text-xs transition-colors ${isUpcoming ? "text-neon-orange hover:text-neon-orange/80" : "text-neon-blue hover:text-neon-blue/80"}`}
                >
                  詳細を見る
                  <!-- ExternalLink icon -->
                  <svg class="h-3 w-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
              )}
            </div>
          </div>
        )
      })}
    </div>
  </div>
</section>

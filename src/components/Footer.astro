---
const socialLinks = [
  {
    label: "X (Twitter)",
    href: "https://twitter.com/pokorinta",
    colorClass: "hover:text-neon-blue hover:border-neon-blue",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.626zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
  {
    label: "YouTube",
    href: "https://youtube.com/@pokorinta",
    colorClass: "hover:text-neon-orange hover:border-neon-orange",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  },
  {
    label: "Instagram",
    href: "https://instagram.com/pokorinta",
    colorClass: "hover:text-neon-blue hover:border-neon-blue",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>`,
  },
]
---

<footer class="relative border-t border-border/50 bg-background">
  <!-- Circuit pattern decoration -->
  <div class="absolute inset-0 overflow-hidden opacity-5">
    <div class="absolute -left-4 top-0 h-full w-px bg-gradient-to-b from-neon-blue via-transparent to-neon-orange"></div>
    <div class="absolute -right-4 top-0 h-full w-px bg-gradient-to-b from-neon-orange via-transparent to-neon-blue"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 py-16 md:px-6">
    <div class="flex flex-col items-center gap-8">
      <!-- Logo -->
      <div class="text-center">
        <h3 class="font-mono text-2xl font-bold tracking-tight text-foreground">
          Pokorinta<span class="text-neon-blue"> Laboratory</span>
        </h3>
        <p class="mt-2 font-mono text-sm text-muted-foreground">自動打楽器開発サークル</p>
      </div>

      <!-- Social links -->
      <div class="flex items-center gap-4">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class={`group flex h-12 w-12 items-center justify-center rounded-lg border border-border/50 bg-card/30 text-muted-foreground transition-all duration-300 ${link.colorClass}`}
            aria-label={link.label}
            set:html={link.icon}
          />
        ))}
      </div>

      <!-- Contact prompt -->
      <div class="text-center">
        <p class="font-mono text-sm text-muted-foreground">
          お仕事のご依頼・取材はSNSのDMまでお気軽にどうぞ
        </p>
      </div>

      <!-- Divider -->
      <div class="h-px w-full max-w-xs bg-gradient-to-r from-transparent via-border to-transparent"></div>

      <!-- Copyright -->
      <div class="flex flex-col items-center gap-2 text-center">
        <p class="font-mono text-xs text-muted-foreground">
          © {new Date().getFullYear()} Pokorinta Laboratory. All rights reserved.
        </p>
        <div class="flex items-center gap-2 font-mono text-xs text-muted-foreground/60">
          <span>Made with</span>
          <span class="text-neon-orange">♥</span>
          <span>&</span>
          <span class="text-neon-blue">ESP32</span>
        </div>
      </div>
    </div>
  </div>
</footer>
